{
  "name": "@cybercussion/scobot",
  "version": "5.2.2",
  "publishConfig": {
    "access": "public"
  },
  "description": "Modern, Native JavaScript SCORM (1.2/2004) Library",
  "homepage": "https://scobot.cybercussion.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cybercussion/SCOBot.git"
  },
  "bugs": {
    "url": "https://github.com/cybercussion/SCOBot/issues"
  },
  "type": "module",
  "main": "./dist/scobot.umd.cjs",
  "module": "./dist/scobot.js",
  "exports": {
    ".": {
      "import": "./dist/scobot.js",
      "require": "./dist/scobot.umd.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "types": "./dist/types/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:types && vite build",
    "build:types": "tsc",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "SCORM",
    "SCORM 1.2",
    "SCORM 2004",
    "e-learning",
    "content"
  ],
  "author": "Cybercussion Interactive, LLC",
  "license": "CC-BY-SA-4.0",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^23.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "lz-string": "^1.5.0"
  }
}
